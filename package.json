{
  "name": "openmap",
  "version": "0.3.0",
  "description": "Personal place memory graph + intent search for AI agents. Mem0 x Tavily, for places.",
  "type": "module",
  "license": "MIT",
  "keywords": [
    "agents",
    "memory",
    "places",
    "geo",
    "mcp",
    "llm",
    "search"
  ],
  "engines": {
    "node": ">=22.5"
  },
  "bin": {
    "openmap": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "ARCHITECTURE.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli.ts",
    "openmap": "tsx src/cli.ts",
    "test": "node --import tsx --test --experimental-test-coverage test/*.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "eval": "tsx eval/run.ts",
    "eval:compare": "tsx eval/compare.ts",
    "eval:recall": "tsx eval/recall.ts",
    "mcp": "tsx src/mcp.ts"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "sqlite-vec": "^0.1.7-alpha.2",
    "zod": "^3.23.8"
  },
  "optionalDependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "openai": "^4.60.0"
  },
  "devDependencies": {
    "@types/node": "^22.7.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
